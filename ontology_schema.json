{
  "schema_version": "1.1",
  "description": "Combined clinical extraction ontology for clinic notes, annual wellness visits, cardiology/consult notes, and problem-list style EHR exports. Designed to drive section detection, entity extraction, normalization (SNOMED), and mapping to ICD-10-CM.",
  "document_types": [
    "discharge_summary",
    "progress_note",
    "office_visit",
    "annual_wellness_visit",
    "cardiology_note",
    "consult_note",
    "radiology_report",
    "problem_list_export"
  ],
  "global_options": {
    "min_section_length_chars": 20,
    "ocr_confidence_threshold": 0.75,
    "language": "en",
    "date_formats": [
      "MM/DD/YYYY",
      "M/D/YY",
      "YYYY-MM-DD",
      "DD/MM/YYYY",
      "MMM D, YYYY"
    ],
    "page_number_capture": true
  },
  "sections": {
    "chief_complaint": {
      "anchors": ["Chief Complaint", "CC:", "Reason for Visit", "Reason:"],
      "priority": 1,
      "stop_anchors": ["History of Present Illness", "HPI", "Assessment", "Plan", "Subjective"],
      "capture_mode": "first_paragraph"
    },
    "history_of_present_illness": {
      "anchors": ["History of Present Illness", "HPI", "History:", "History of Present Illness:"],
      "priority": 2,
      "stop_anchors": ["Review of Systems", "ROS", "Assessment", "Plan", "Physical Exam"]
    },
    "review_of_systems": {
      "anchors": ["Review of Systems", "ROS"],
      "priority": 3,
      "stop_anchors": ["Physical Exam", "PE", "Assessment"]
    },
    "physical_exam": {
      "anchors": ["Physical Exam", "Exam", "PE:", "Physical Examination"],
      "priority": 4,
      "stop_anchors": ["Assessment", "Plan", "Medications"]
    },
    "assessment_and_plan": {
      "anchors": ["Assessment and Plan", "Assessment & Plan", "A/P", "Assessment:"],
      "priority": 0,
      "stop_anchors": ["Medications", "Allergies", "Follow-up", "Plan of Treatment"],
      "capture_mode": "block",
      "notes": "High priority for final diagnoses and plan — prefer when present"
    },
    "problem_list": {
      "anchors": ["Problem List", "Problems", "Problem List:", "Problem(s):", "Problems Reviewed"],
      "priority": 1,
      "stop_anchors": ["Medications", "Allergies", "History of Present Illness"],
      "pattern": "(?m)^[0-9]*\\.?\\s*([A-Za-z].+)$"
    },
    "past_medical_history": {
      "anchors": ["Past Medical History", "PMH", "Past Medical History:"],
      "priority": 5,
      "stop_anchors": ["Surgical History", "Medications", "Allergies"]
    },
    "past_surgical_history": {
      "anchors": ["Past Surgical History", "PSH", "Surgical History"],
      "priority": 6
    },
    "medications": {
      "anchors": ["Medications", "Current Medications", "Medication History", "Medications Reconciled"],
      "priority": 3,
      "capture_mode": "list",
      "list_item_pattern": "(?m)^\\s*[-•\\d\\)\\.]*\\s*([A-Za-z0-9\\-\\s\\/\\(\\)%,]+)\\s+\\d+\\s*(mg|mcg|units|tablet|tab|capsule|caps)?" ,
      "structured_fields": ["name", "dose", "route", "sig", "start_date", "end_date"]
    },
    "allergies": {
      "anchors": ["Allergies", "Allergic", "Allergy"],
      "priority": 3,
      "capture_mode": "list",
      "list_item_pattern": "(?m)^\\s*[-•\\d\\)\\.]*\\s*([A-Za-z0-9\\-\\s]+)\\s*(Reaction:|Reaction|-)?\\s*([A-Za-z,\\s]*)"
    },
    "vitals": {
      "anchors": ["Vital Signs", "Vitals", "Vitals:", "BP:", "Height", "Weight", "BMI"],
      "priority": 6,
      "capture_mode": "block",
      "patterns": {
        "blood_pressure": "(?i)BP[:\\s]+(\\d{2,3}/\\d{2,3})",
        "heart_rate": "(?i)Pulse[:\\s]+(\\d{2,3})",
        "weight": "(?i)Weight[:\\s]+(\\d{2,3}(?:\\.\\d)?)\\s*(lb|kg)?",
        "height": "(?i)Ht[:\\s]+([0-9'\\\"]+|\\d{2,3} ?in|\\d{2,3} ?cm)",
        "bmi": "(?i)BMI[:\\s]+(\\d{1,3}\\.\\d{1,2}|\\d{1,2})"
      }
    },
    "labs": {
      "anchors": ["Laboratory", "Labs", "Results", "Lab Results", "Lab:"],
      "priority": 7,
      "capture_mode": "table_or_block",
      "table_detection": true,
      "value_pattern": "(?m)^\\s*([A-Za-z0-9\\s\\-\\%\\_\\(\\)\\/]+)\\s+([0-9\\.\\<\\>\\-a-zA-Z]+)\\s+([A-Za-z0-9\\s\\(\\)%,]*)"
    },
    "imaging_and_tests": {
      "anchors": ["Imaging Results", "Imaging", "ECG", "Electrocardiogram", "Imaging Results:"],
      "priority": 8
    },
    "procedures": {
      "anchors": ["Procedures", "Surgeries", "Operative", "Procedure:"],
      "priority": 9
    },
    "health_maintenance": {
      "anchors": ["Health Maintenance", "Health Maintenance History", "Vaccinations", "Immunization"],
      "priority": 10
    },
    "family_history": {
      "anchors": ["Family History", "FH"],
      "priority": 11
    },
    "social_history": {
      "anchors": ["Social History", "SH"],
      "priority": 11
    },
    "plan": {
      "anchors": ["Plan", "Plan:", "Plan of Treatment", "Current Plans"],
      "priority": 0,
      "stop_anchors": ["Follow-up", "Appointments"]
    },
    "follow_up": {
      "anchors": ["Follow-up", "Follow up", "Appointments", "Return to clinic"],
      "priority": 12
    },
    "notes_footer": {
      "anchors": ["Signature", "Provider", "Dictated by", "Electronic Signature"],
      "priority": 99
    }
  },
  "entities": {
    "Diagnosis": {
      "display": "Diagnosis / Condition",
      "detection": {
        "pattern_rules": [
          {"regex": "(?i)diagnosis[:\\s]*([A-Za-z0-9\\s\\-\\/,\\(\\)]+)"},
          {"regex": "(?m)^\\s*Problems?\\s*[:\\-]\\s*(.+)$"},
          {"regex": "(?m)^[0-9]+\\.\\s*([A-Z].+)$"}
        ],
        "model_based": {
          "type": "llm",
          "prompt_template": "Extract diagnoses and short qualifiers (status, laterality, chronicity) from SECTION_TEXT and return json with text and context"
        }
      },
      "attributes": {
        "status": {
          "type": "enum",
          "values": ["active", "resolved", "history", "rule_out", "suspected", "chronic", "acute", "stable", "worsening"]
        },
        "onset_date": {
          "type": "date",
          "detection_patterns": ["since", "onset", "started", "diagnosed", "dx"]
        },
        "laterality": {
          "type": "enum",
          "values": ["left", "right", "bilateral", "unspecified"]
        },
        "severity": {
          "type": "string"
        },
        "meat_evidence": {
          "type": "object",
          "properties": {
            "medication": {"type": "array"},
            "exam": {"type": "array"},
            "age": {"type": "array"},
            "test": {"type": "array"},
            "notes": {"type": "array"}
          }
        }
      },
      "normalization": {
        "preferred_vocabulary": "SNOMED-CT",
        "normalizer": {
          "type": "hybrid",
          "order": ["lexical_map", "approx_string_match", "llm_normalize"],
          "llm_prompt": "Map the extracted clinical concept to the best matching SNOMED-CT concept and provide the preferred term and SNOMED code."
        }
      },
      "provenance": {
        "record_text_sample": true,
        "page": true,
        "char_offsets": true
      }
    },
    "Medication": {
      "display": "Medication",
      "detection": {
        "pattern_rules": [
          {"regex": "(?mi)^(?:\\-\\s*)?([A-Za-z0-9\\-\\(\\)\\/\\s]+)\\s+(\\d+\\s*(mg|mcg|units|g|ml|tablet|tab|caps)?)"},
          {"regex": "(?i)Take\\s+([0-9a-zA-Z\\s]+)\\s+(by mouth|PO|oral|daily|qd|bid|tid|hs|at bedtime)"}
        ],
        "model_based": {"type": "llm"}
      },
      "attributes": ["name", "dose", "route", "frequency", "start_date", "stop_date", "prescribed_by"],
      "normalization": {"preferred_vocabulary": "RxNorm"}
    },
    "Allergy": {
      "display": "Allergy",
      "detection": {"pattern_rules": [{"regex": "(?mi)^(?:NKDA|No Known Drug Allergies|No Known Allergies)"}]},
      "attributes": ["substance", "reaction", "severity", "onset_date"]
    },
    "LabResult": {
      "display": "Lab Result",
      "detection": {"table_based": true, "pattern_rules": []},
      "attributes": ["test_name", "value", "units", "reference_range", "date"]
    },
    "Procedure": {
      "display": "Procedure",
      "detection": {"pattern_rules": [{"regex": "(?i)Procedure[s]?:|Surgery|Operative|s/p"}]},
      "attributes": ["procedure_name", "date", "laterality", "notes"]
    },
    "ImagingFinding": {
      "display": "Imaging/Study",
      "detection": {"pattern_rules": [{"regex": "(?i)Imaging Results|ECG|X[- ]?ray|CT|MRI|Ultrasound|Echo|TTE|TEE"}]},
      "attributes": ["study_name", "date", "result_summary"]
    }
  },
  "mapping": {
    "default_map_source": "llm_snomed_to_icd10",
    "icd10_map_strategy": {
      "primary": "map_normalized_snomed_to_icd10",
      "fallbacks": ["llm_map_text_to_icd10_candidates", "lookup_common_mappings"],
      "max_candidates": 5,
      "prefer_specific_codes": true
    },
    "rules": [
      {
        "name": "prefer_assessment_for_primary_dx",
        "when": {"entity": "Diagnosis"},
        "action": {"prefer_section": ["assessment_and_plan", "problem_list", "past_medical_history"]}
      },
      {
        "name": "exclude_screening_codes_from_primary",
        "when": {"entity_text_matches": ["screening", "wellness", "vaccination"]},
        "action": {"map_to": "Z00.00", "confidence_boost": -0.1}
      }
    ]
  },
  "post_processing": {
    "deduplicate_by_normalized_concept": true,
    "deduplication_threshold": 0.88,
    "prefer_higher_priority_section": true,
    "keep_multiple_presentations": false,
    "meat_rules": {
      "evidence_types": ["Medication", "LabResult", "ImagingFinding", "Procedure", "PhysicalExam"],
      "min_evidence_for_active": 1,
      "prioritize_medications_and_tests": true
    },
    "confidence_thresholds": {
      "entity_extraction": 0.6,
      "normalization": 0.5,
      "icd10_mapping": 0.4
    }
  },
  "logging_and_provenance": {
    "record_extraction_id": true,
    "timestamp_format": "ISO8601",
    "include_anchors_matched": true,
    "store_section_char_offsets": true
  }
}
